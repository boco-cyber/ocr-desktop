{
  "name": "ocr-desktop",
  "version": "1.0.0",
  "description": "AI-powered OCR desktop app — extract text from images and PDFs using Anthropic, OpenAI, Gemini, or Ollama",
  "main": "electron.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build": "electron-builder --win portable"
  },
  "dependencies": {
    "canvas": "^2.11.2",
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "express": "^4.18.2",
    "fs-extra": "^11.2.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "pdf2pic": "^3.1.1",
    "pdfjs-dist": "^4.4.168",
    "sharp": "^0.33.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.ocr-desktop.app",
    "productName": "OCR Desktop",
    "files": [
      "electron.js",
      "server.js",
      "index.html",
      "providers/**/*",
      "converters/**/*",
      "output/**/*",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*"
    ],
    "extraResources": [],
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "icon": "icon.png",
      "forceCodeSigning": false,
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "ocr-desktop.exe"
    },
    "directories": {
      "output": "dist-electron"
    },
    "asar": true
  },
  "engines": { "node": ">=18.0.0" }
}
