{
  "name": "ocr-desktop",
  "version": "1.0.0",
  "description": "AI-powered OCR desktop app — extract text from images and PDFs using Anthropic, OpenAI, Gemini, or Ollama",
  "main": "electron.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build": "npm run build:installer",
    "build:portable": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "express": "^4.18.2",
    "fs-extra": "^11.2.0",
    "iconv-lite": "^0.6.3",
    "jschardet": "^3.1.4",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdf-to-img": "^5.0.0",
    "pdf2pic": "^3.1.1",
    "sharp": "^0.33.0",
    "tesseract.js": "^5.1.1",
    "uuid": "^9.0.0",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.ocr-desktop.app",
    "productName": "OCR Desktop",
    "files": [
      "electron.js",
      "preload.js",
      "server.js",
      "index.html",
      "main/**/*",
      "workers/**/*",
      "providers/**/*",
      "converters/**/*",
      "output/**/*",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "forceCodeSigning": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "artifactName": "ocr-desktop-setup-${version}.exe"
    },
    "portable": {
      "artifactName": "ocr-desktop-portable-${version}.exe"
    },
    "directories": {
      "output": "dist-electron"
    },
    "asar": false
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
